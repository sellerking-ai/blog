<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">Seller King <span class="ai">AI</span></span>
      <p>Atendimento Inteligente. Resultados Reais.</p>
    </div>
    <div class="footer-links">
      <a href="https://sellerkingai.com" target="_blank">Site Principal</a>
      <a href="/blog">Blog</a>
      <a href="/about">Sobre</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>© {new Date().getFullYear()} Seller King AI. Todos os direitos reservados.</span>
  </div>
</footer>
<style>
  .site-footer {
    background: #07152E;
    border-top: 1px solid rgba(13, 75, 255, 0.2);
    margin-top: 4rem;
    padding: 3rem 2rem 1.5rem;
  }
  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }
  .footer-logo {
    font-family: 'Rajdhani', sans-serif;
    font-size: 1.4rem;
    font-weight: 700;
    color: #E8ECF4;
    display: block;
    margin-bottom: 0.5rem;
  }
  .footer-logo .ai { color: #00AFFF; }
  .footer-brand p {
    color: #5A6475;
    font-size: 0.85rem;
    margin: 0;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }
  .footer-links a {
    color: #AEB7C5;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }
  .footer-links a:hover { color: #5FD7FF; }
  .footer-bottom {
    max-width: 1200px;
    margin: 0 auto;
    border-top: 1px solid rgba(90, 100, 117, 0.2);
    padding-top: 1.5rem;
    color: #5A6475;
    font-size: 0.8rem;
  }
</style>
