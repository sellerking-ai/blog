---
---
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="logo-link">
           <div class="logo-text">
        <span class="logo-title">Seller King <span class="ai-badge">AI</span></span>
        <span class="logo-sub">Blog Vendas</span>
      </div>
    </a>
    <nav class="nav">
      <a href="/">Home</a>
      <a href="/blog">Blog</a>
      <a href="/about">Sobre</a>
      <a href="https://sellerkingai.com" target="_blank" class="nav-cta">Ver Planos</a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(2, 6, 17, 0.85);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(13, 75, 255, 0.2);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 70px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
  }

  .logo-img {
    height: 44px;
    width: 44px;
    object-fit: contain;
    filter: drop-shadow(0 0 8px rgba(13, 75, 255, 0.6));
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-title {
    font-family: 'Rajdhani', sans-serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: #E8ECF4;
    letter-spacing: 0.02em;
  }

  .ai-badge {
    color: #00AFFF;
    font-weight: 800;
  }

  .logo-sub {
    font-size: 0.65rem;
    color: #5A6475;
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav a {
    color: #AEB7C5;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    transition: color 0.2s;
  }

  .nav a:hover {
    color: #5FD7FF;
  }

  .nav-cta {
    background: linear-gradient(135deg, #0D4BFF, #00AFFF);
    color: #fff !important;
    padding: 0.5rem 1.25rem;
    border-radius: 6px;
    font-weight: 600 !important;
    transition: opacity 0.2s, box-shadow 0.2s !important;
    box-shadow: 0 0 16px rgba(13, 75, 255, 0.4);
  }

  .nav-cta:hover {
    opacity: 0.9;
    box-shadow: 0 0 24px rgba(0, 175, 255, 0.5) !important;
    color: #fff !important;
  }

  @media (max-width: 640px) {
    .nav a:not(.nav-cta) { display: none; }
    .logo-sub { display: none; }
  }
</style>
